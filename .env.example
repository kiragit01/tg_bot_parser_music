# ==========================================
# Telegram Bot
# ==========================================
# Токен бота — получить у @BotFather в Telegram:
#   1. Открой @BotFather → /newbot → придумай имя и username
#   2. Скопируй токен вида 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELOXIDE_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# ==========================================
# VK (основной источник музыки, без цензуры)
# ==========================================
# Получить токен:
#   1. Перейди по ссылке (Kate Mobile):
#      https://oauth.vk.com/authorize?client_id=2685278&scope=audio&response_type=token&v=5.131
#   2. Залогинься и разреши доступ
#   3. Из URL после редиректа скопируй access_token=СЮДА_ТОКЕН
# Можно указать несколько через запятую для ротации (снижает шанс бана):
#   VK_TOKEN=token1,token2,token3
VK_TOKEN=

# ==========================================
# SoundCloud (OAuth токен, решает 401 ошибки)
# ==========================================
# Получить:
#   1. Открой https://soundcloud.com и залогинься
#   2. DevTools (F12) → Network → фильтр "api-v2"
#   3. Кликни на любой запрос к api-v2.soundcloud.com
#   4. В заголовках найди Authorization: OAuth XXXXX
#   5. Скопируй XXXXX (без "OAuth " в начале)
# Можно несколько через запятую:
#   SC_OAUTH_TOKEN=token1,token2
SC_OAUTH_TOKEN=

# ==========================================
# Genius (тексты песен)
# ==========================================
# Получить:
#   1. Зайди на https://genius.com/api-clients/new
#   2. Заполни: App Name — любое, App Website URL и Redirect URI — http://localhost
#   3. Нажми Save → на странице приложения скопируй "Client Access Token"
# Можно несколько через запятую:
#   GENIUS_TOKEN=token1,token2
GENIUS_TOKEN=

# ==========================================
# Настройки
# ==========================================
# Параллельность скачивания (по умолчанию 10, глобально на всех пользователей)
MAX_CONCURRENT=10

# Уровень логирования (trace, debug, info, warn, error)
RUST_LOG=info
