# Токен Telegram бота (получить у @BotFather)
TELOXIDE_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Токен VK для скачивания музыки (основной источник, без цензуры)
# Получить: https://oauth.vk.com/authorize?client_id=2685278&scope=audio&response_type=token&v=5.131
# Скопировать access_token из URL после редиректа
VK_TOKEN=

# SoundCloud OAuth токен (решает 401 ошибки, больше треков)
# Получить: открой SoundCloud в браузере, DevTools → Network → любой запрос к api-v2.soundcloud.com
# Скопируй значение заголовка Authorization (без "OAuth " в начале)
SC_OAUTH_TOKEN=

# Параллельность скачивания (по умолчанию 10, глобально на всех пользователей)
MAX_CONCURRENT=10

# Уровень логирования
RUST_LOG=info
